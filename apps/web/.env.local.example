# Copy to .env.local — these are PUBLIC (safe to expose in browser)
NEXT_PUBLIC_SUPABASE_URL=https://mngykqbmtlbkuztrugkl.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=   # Supabase Dashboard → Settings → API → anon key
NEXT_PUBLIC_API_URL=http://localhost:8000   # FastAPI local; set to Railway URL in prod
NEXT_PUBLIC_APP_URL=https://groupholidaybooking.com  # canonical URL for sitemap/robots

# ── Affiliate IDs (optional — leave blank until accounts are approved) ─────────
# Booking.com Direct Partner Hub: partners.booking.com → Account → aid
# (Direct programme is increasingly selective for new affiliates.)
NEXT_PUBLIC_BOOKING_COM_AID=
# CJ Affiliate (Commission Junction) — easier route for Booking.com in 2026.
# Get your Publisher ID from members.cj.com → Account → Account Information.
# Advertiser ID 4297311 is Booking.com UK (already defaulted in code).
NEXT_PUBLIC_CJ_PID=
NEXT_PUBLIC_CJ_BOOKING_AID=4297311
# Trainline affiliate via Partnerize (Trainline moved off Awin in 2024).
# Sign up at join.partnerize.com/trainline/en — once approved, copy your camref.
NEXT_PUBLIC_TRAINLINE_CAMREF=

# ── One-off calendar import (any account, no permanent link) ───────────────────
# Google: Cloud Console → Credentials → OAuth client (Web). Add your site +
# localhost:3000 as Authorised JavaScript origins. Paste the Client ID here.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
# Microsoft: Azure Portal → App registrations → New. Platform = SPA, redirect
# URIs = your site origin(s) + http://localhost:3000. API permission =
# Microsoft Graph → Calendars.Read (delegated). Paste the Application (client) ID.
NEXT_PUBLIC_MS_CLIENT_ID=
