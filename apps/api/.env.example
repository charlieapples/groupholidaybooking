# Copy to .env and fill in values for local dev.
# On Railway, set these in the project's Variables tab instead.

# Existing (already in your root .env)
TRAVELPAYOUTS_TOKEN=
GOOGLE_MAPS_API_KEY=

# New for v2
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
GEMINI_API_KEY=

# CORS allowed origins (comma-separated). Add your Vercel URL here in prod.
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Optional
BOOKING_AFFILIATE_ID=
TRAINLINE_AWIN_ID=
