# Copy to .env and fill in values for local dev.
# On Railway, set these in the project's Variables tab instead.

# ── Core ──────────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
GEMINI_API_KEY=                       # aistudio.google.com
GEMINI_MODEL=gemini-2.5-flash         # optional override; bump when Google retires a model

# ── Flight & ground transport ─────────────────────────────────────────────────
TRAVELPAYOUTS_TOKEN=                  # API auth: app.travelpayouts.com/profile → API Token
TRAVELPAYOUTS_MARKER=                 # Affiliate tracking ID (DIFFERENT from token!)
                                      # Find it in lower-left of Travelpayouts dashboard.
                                      # Without it, Aviasales clicks don't earn commission.
GOOGLE_MAPS_API_KEY=                  # Google Cloud → APIs → Distance Matrix API

# ── Email (Resend — free tier: 3,000 emails/month) ───────────────────────────
RESEND_API_KEY=re_...                 # resend.com/api-keys
EMAIL_FROM=Group Holiday <noreply@yourdomain.com>  # verified sender
APP_URL=https://groupholidaybooking.com     # used in email deep-links

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated. Add your Vercel deployment URL in prod.
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://groupholidaybooking.com

# ── Permanent calendar linking (link once, reuse every Holiday) ───────────────
# Server-side OAuth (authorization-code flow) to store encrypted refresh tokens.
# Absent any of these, the feature reports configured:false and the UI hides.
API_PUBLIC_URL=http://localhost:8000        # this API's public base (Railway URL in prod)
# Generate once: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CALENDAR_TOKEN_KEY=
# Google: same OAuth client as the one-off import, but you also need the SECRET,
# and add  <API_PUBLIC_URL>/api/calendars/google/callback  as an Authorized
# redirect URI (Web application) in Google Cloud Console.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Microsoft: Azure app — add a client SECRET (Certificates & secrets) and add
# <API_PUBLIC_URL>/api/calendars/microsoft/callback as a WEB redirect URI.
MS_OAUTH_CLIENT_ID=
MS_OAUTH_CLIENT_SECRET=

# ── Optional affiliate IDs ────────────────────────────────────────────────────
BOOKING_AFFILIATE_ID=
TRAINLINE_AWIN_ID=
